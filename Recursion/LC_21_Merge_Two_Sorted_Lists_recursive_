class Solution {
public:
    ListNode* mergeTwoLists(ListNode* list1, ListNode* list2) {
        
        // base case: agar koi bhi list null hai
        // to doosri list directly return karo
        // kyunki null se kuch merge nahi karna
        if(list1 == NULL) return list2;
        if(list2 == NULL) return list1;
        
        // compare karo dono lists ki current values
        if(list1->val <= list2->val) {
            // list1 choose kiya kyunki wo choti hai
            // list1 ke next mein aage ki merged list attach karo
            // matlab list1->next aur list2 ko merge karte raho recursively
            // list1 mein hi sab merge ho raha hai isliye list1 return
            list1->next = mergeTwoLists(list1->next, list2);
            return list1;
        }
        else {
            // list2 choose kiya kyunki wo choti hai
            // list2 ke next mein aage ki merged list attach karo
            // matlab list1 aur list2->next ko merge karte raho recursively
            // list2 mein hi sab merge ho raha hai isliye list2 return
            list2->next = mergeTwoLists(list1, list2->next);
            return list2;
        }
    }
};

/*
INTUITION:
Compare → Choose smaller → Attach merged rest → Return chosen

BASE CASE:
list1 null → return list2 (list2 already sorted hai)
list2 null → return list1 (list1 already sorted hai)

EXAMPLE:
merge(1→2→4, 1→3→4)
1==1 → list1 choose → list1->next = merge(2→4, 1→3→4)
                       2>1 → list2 choose → list2->next = merge(2→4, 3→4)
                              2<3 → list1 choose → ...
Result: 1→1→2→3→4→4 ✅

TIME:  O(m+n) — dono lists ke saare nodes visit honge
SPACE: O(m+n) — recursion call stack
*/

ListNode* mergeTwoLists(ListNode* list1, ListNode* list2) {
    
    // dummy node banao — isse starting easy hoti hai
    // actual answer dummy->next se shuru hoga
    ListNode* dummy = new ListNode(0);
    ListNode* curr = dummy;  // curr se traverse karenge
    
    // jab tak dono lists mein elements hain
    while(list1 != NULL && list2 != NULL) {
        
        // compare karo, chota wala attach karo
        if(list1->val <= list2->val) {
            curr->next = list1;   // list1 attach kiya
            list1 = list1->next;  // list1 aage badhi
        }
        else {
            curr->next = list2;   // list2 attach kiya
            list2 = list2->next;  // list2 aage badhi
        }
        curr = curr->next;  // curr bhi aage badha
    }
    
    // jo list abhi baki hai use directly attach karo
    // kyunki wo already sorted hai
    if(list1 != NULL) curr->next = list1;
    if(list2 != NULL) curr->next = list2;
    
    // dummy->next hai actual answer
    return dummy->next;
}

/*
ITERATIVE vs RECURSIVE:
Iterative → dummy node + curr pointer + while loop
Recursive → base case + compare + recursive call

Iterative better hai space wise → O(1) extra space
Recursive → O(m+n) call stack space

DUMMY NODE kyun?
Pehle node attach karne ke liye special case avoid hota hai
dummy->next se actual list start hoti hai
*/
