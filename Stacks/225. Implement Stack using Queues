// Stack using Queue
// Idea: Queue ko rotate karke LIFO behaviour banana

// push:
// 1. push element
// 2. rotate (size-1 times)

// pop:
// directly front remove

// top:
// front element

// empty:
// queue empty check

// Time Complexity:
// push = O(n)
// pop = O(1)
// top = O(1)
class MyStack {
public:
    queue<int> q;

    MyStack() {}

    void push(int x) {
        q.push(x);
        int size = q.size();

        // rotate previous elements
        for(int i = 0; i < size - 1; i++) {
            q.push(q.front());
            q.pop();
        }
    }

    int pop() {
        int top = q.front();
        q.pop();
        return top;
    }

    int top() {
        return q.front();
    }

    bool empty() {
        return q.empty();
    }
};
