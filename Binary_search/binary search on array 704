class Solution {
public:
    int search(vector<int>& nums, int target) {
        int n = nums.size();
        int low = 0;
        int high = n-1;
        
        while (low <= high){
            int mid = low + (high - low )/2;
            if(nums[mid] == target ) return mid; 
            // mid is index .. target should be compared to nums ke and mid index p jo value h 
            else if( nums[mid] < target ){
                low = mid + 1;
            }
            else{
                high = mid-1;
            }
        }
        return -1;
    }
};
