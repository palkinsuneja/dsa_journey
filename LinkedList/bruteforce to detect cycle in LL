class Solution {
public:
    bool hasCycle(ListNode *head) {
        map < ListNode * , int > visited ;

        ListNode * temp = head; 

        while (temp != NULL ){
            //if()
            if (visited.find (temp) != visited.end()){
                return true ;
            }
            else {//else lagao ya na lagao → same logic means niche ki 2 loc bina else bhi likh skte the. 
                visited[temp]= 1;
                temp = temp -> next;
            }
        }
        return false;
    }
};
