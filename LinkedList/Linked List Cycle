/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode(int x) : val(x), next(NULL) {}
 * };
agar cycle hai:
    fast slow ko pakad lega (due to speed difference)

agar cycle nahi hai:
    fast NULL tak pahunch jayega

	slow → 1 step ✔️
	•	fast → 2 step ✔️
	•	agar mile → cycle ✔️
	•	agar fast null pe pahunch gaya → no cycle ✔️
"If a cycle exists, fast pointer will eventually meet slow pointer
due to relative speed difference."

 */
class Solution {
public:
    bool hasCycle(ListNode *head) {
        if(head == NULL) return false; // khali list

        ListNode* slow = head;
        ListNode* fast = head;

        while(fast != NULL && fast->next != NULL){
            slow = slow->next;          // 1 step
            fast = fast->next->next;    // 2 step

            if(slow == fast){
                return true;  // 🔥 cycle found
            }
        }

        return false; // 🔥 no cycle // agar true nhi aaya or loop khtm to mtlb cycle nhi h to return false
    }
};
