/** OPTIMAL approach
🔥 Interview Line
"I used two pointers to segregate odd and even nodes in-place and 
finally connected both lists"🔥 

3 pointers use:
1. odd → first node
2. even → second node
3. evenHead → even list का start

Odd pointer → skip करके next odd जोड़ता है  
Even pointer → skip करके next even जोड़ता है  

End में:
Odd list + Even list connect

👉 Nodes rearrange हो रहे हैं (values नहीं बदल रहे)
👉 In-place solution
👉 No extra space

if(head == NULL || head->next == NULL)
    return head;
Time: O(n)  
Space: O(1)

 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* oddEvenList(ListNode* head) {
        //base case
        if (head == NULL || head->next == NULL ) return head;
        ListNode* odd = head;
        ListNode* even = head-> next;
        ListNode* evenhead = head-> next; 
        
        //rearrange 
        while(even != NULL && even->next != NULL){
            odd->next= even->next; //odd to odd link 
            odd= odd->next;

            even->next = odd->next;
            even = even -> next ;
            
        }
        // connect odd list to even list
        odd->next = evenhead ;
        return head;
    }
};

// Brute
/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* oddEvenList(ListNode* head) {
        //int data ;
        if (head == NULL || head->next == NULL ) return head;
        vector<int> arr = { };
        ListNode* temp = head;
        while(temp != NULL && temp->next != NULL){
            arr.push_back(temp -> val);
            temp = temp-> next -> next;
        }
        if (temp != NULL) arr.push_back(temp->val);

        temp= head-> next; 
        while(temp != NULL && temp->next != NULL){
            arr.push_back(temp -> val);
            temp = temp-> next -> next;
        }
        if (temp != NULL) arr.push_back(temp->val);

        int i = 0 ; temp = head;
        while(temp != NULL){
            temp-> val= arr[i];
            i++;
            temp = temp -> next;

        }
        return head;
    }
};
